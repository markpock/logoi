---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteTitle } from "../site.config.mjs";

const about = await getEntry("pages", "about");
if (!about) {
  throw new Error("Missing about page content");
}

const { Content } = await about.render();
---

<BaseLayout title={siteTitle(about.data.title)} description={about.data.description}>
  <article class="about-page">
    <h1>{about.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
