---
import { getCollection } from "astro:content";
import ArticleSidebar from "../../components/ArticleSidebar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostNav from "../../components/PostNav.astro";
import { siteTitle } from "../../site.config.mjs";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes
    .filter((note) => !note.data.draft)
    .map((note) => ({
      params: { slug: note.slug },
      props: { note },
    }));
}

const { note } = Astro.props;
const notes = (await getCollection("notes"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = notes.findIndex((entry) => entry.slug === note.slug);
const previousNote = notes[currentIndex + 1];
const nextNote = notes[currentIndex - 1];

const relatedNotes = notes
    .filter((entry) => entry.slug !== note.slug)
    .filter((entry) => entry.data.tags.some((tag) => note.data.tags.includes(tag)))
    .slice(0, 3)
// Getting rid of related notes for now -- I want to make them explicitly supplied.
const sidebarRelated = (relatedNotes.length > 0
  ? relatedNotes
  : notes.filter((entry) => entry.slug !== note.slug).slice(0, 3)).filter(() => false);
  
const { Content, headings } = await note.render();
const pageHeadings = headings.filter(
  (heading) =>
    heading.depth >= 2 &&
    heading.depth <= 3 &&
    heading.slug !== "footnotes" &&
    heading.slug !== "footnote-label"
);
const tableOfContents = pageHeadings.reduce((items, heading) => {
  if (heading.depth === 2) {
    items.push({ ...heading, children: [] });
  } else {
    const parent = items[items.length - 1];
    if (parent) {
      parent.children.push(heading);
    }
  }
  return items;
}, []);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    timeZone: "UTC",
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<BaseLayout
  title={siteTitle(note.data.title)}
  description={note.data.description}
  bodyClass="article-body">
  <div class="article-layout">
    <ArticleSidebar
      note={note}
      pageHeadings={pageHeadings}
      tableOfContents={tableOfContents}
      sidebarRelated={sidebarRelated}
      formatDate={formatDate}
    />
    <article class="note-page">
      <header>
        <h1>{note.data.title}</h1>
        {note.data.description && <p>{note.data.description}</p>}
      </header>
      <div class="prose">
        <Content />
      </div>
      <PostNav previousNote={previousNote} nextNote={nextNote} />
    </article>
  </div>
</BaseLayout>
