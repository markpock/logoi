---
import { ViewTransitions } from "astro:transitions";
import "katex/dist/katex.min.css";
import SiteHeader from "../components/SiteHeader.astro";
import {
  ASSETS,
  SITE_DESCRIPTION,
  SITE_TITLE,
} from "../site.config.mjs";
import "../styles/global.css";

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
} = Astro.props;
const fontStyles = `
  @font-face {
    font-family: "New Computer Modern";
    font-style: normal;
    font-weight: 400;
    font-display: block;
    src: url("${ASSETS.fonts.regular}") format("opentype");
  }

  @font-face {
    font-family: "New Computer Modern";
    font-style: italic;
    font-weight: 400;
    font-display: block;
    src: url("${ASSETS.fonts.italic}") format("opentype");
  }

  @font-face {
    font-family: "New Computer Modern";
    font-style: normal;
    font-weight: 700;
    font-display: block;
    src: url("${ASSETS.fonts.bold}") format("opentype");
  }

  @font-face {
    font-family: "New Computer Modern";
    font-style: italic;
    font-weight: 700;
    font-display: block;
    src: url("${ASSETS.fonts.boldItalic}") format("opentype");
  }

  :root {
    --tag-icon-mask: url("${ASSETS.tagIcon}") center / contain no-repeat;
  }
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={ASSETS.siteIcon} type="image/svg+xml" />
    <link rel="preload" href={ASSETS.fonts.regular} as="font" type="font/otf" crossorigin />
    <link rel="preload" href={ASSETS.fonts.italic} as="font" type="font/otf" crossorigin />
    <link rel="preload" href={ASSETS.fonts.bold} as="font" type="font/otf" crossorigin />
    <title>{title}</title>
    <style is:inline set:html={fontStyles}></style>
    <style is:inline>
      html,
      body {
        background: #f8f7f4;
      }

      html[data-theme="dark"],
      html[data-theme="dark"] body {
        background: #151615;
      }
    </style>
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = storedTheme || (systemDark ? "dark" : "light");
    </script>
    <script>
      import "../scripts/theme.js";
    </script>
    <ViewTransitions />
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader />
      <main transition:animate="fade">
        <slot />
      </main>
    </div>
    <script>
      import "../scripts/notes-filter.js";
      import "../scripts/quote-reveal.js";
      import "../scripts/tag-popover.js";
    </script>
  </body>
</html>
